# Build output
bin/
obj/

# IDE
.vs/
.vscode/
.idea/
*.user
*.suo

# OS noise
.DS_Store
Thumbs.db

# Third-party JARs — never committed (game assets, decompiler, test mods)
# Vineflower is downloaded automatically by the ModTranspiler build target (LGPL — not bundled)
*.jar
Assets/extracted/

# Mod drop zone — user JARs and compiled plugins are never committed
mods/compiled/*.dll
!mods/.gitkeep
!mods/compiled/.gitkeep

# Decompiler binary — downloaded on first build, not committed (LGPL)
tools/decompiler/*.jar
!tools/decompiler/.gitkeep

# Decompiler and mod working output — contains third-party decompiled code
temp/

# Java build temp
Tools/.build-tmp/

# Published AOT output
publish/

# Debug / verification tools — local only, never committed
Tools/Debug/

# Local environment variables — contains secrets, never committed
.env
