<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>SpectraEngine.ModRuntime</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <!-- IKVM runtime — provides Java semantics on .NET CLR -->
    <PackageReference Include="IKVM" Version="8.*" />
    <!-- HarmonyLib — runtime IL patching (Mixin equivalent for .NET) -->
    <PackageReference Include="Lib.Harmony" Version="2.3.*" />
    <!-- Reference Core for IWorld, IEngine, etc. interfaces -->
    <ProjectReference Include="..\SpectraEngine.csproj" />
  </ItemGroup>
</Project>
